# Secrets — never commit
.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/
dist/
build/
.eggs/

# Logs (runtime output — not source)
logs/

# Snapshots (local data backed up via backup_logs.py, not committed)
data/snapshots/

# Knowledge Base sqlite + sqlite-vec database (local, backed up via backup_logs.py)
data/cora_kb.db
data/cora_kb.db-shm
data/cora_kb.db-wal

# Security monitor runtime data (machine-specific file hashes and alert history)
data/security/

# Claude Code local settings and session worktrees (machine-specific)
.claude/

# OS
.DS_Store
Thumbs.db

# Credentials (private keys)
.credentials/

# Temporary fix/debug scripts (FUSE workarounds — safe to delete from Windows side)
tmp_*.py
tmp_*.txt
data/*.db
data/cache/*.db
data/cache/*.db-shm
data/cache/*.db-wal
data/cache/*.json
data/cache/*.db
data/*_watermarks.json

# Claude session one-shot git helper scripts (root-level only)
# These are generated by Claude Code sessions to run specific git commands.
# They live at the repo root and follow predictable naming conventions.
/cascade-push-*.ps1
/commit-*.ps1
/push-*.ps1
/fire_commit.ps1
/do_commit.py
/run_and_capture.py
/run_commit.bat
/run_tests.bat
/run_tests*.bat
/run_tests.ps1
/run_tests*.ps1
/silent_runner.pyw
/tiny_server.py
/trigger_tests.vbs
/create_task.ps1
/coratest_task.xml

# Session notes and planning artifacts
/_notes/

# Runtime data files (generated at runtime, not source)
data/cora-reply-log.jsonl
data/cora-proposed-memory-updates.jsonl
data/surfaced-decisions.jsonl
data/reconciliation/

# Test output artifacts
scripts/*.png

# Runtime artifacts (2026-06-10 cleanup -- generated by the running service / sweeps)
data/.fuse_hidden*
data/channel-sweep/
data/state/
data/health/heartbeat.txt
data/*.db.bak*
/.git-corrupt-backup/
/backups/
data/health-kb-baseline.json
data/health-flywheel-baseline.json
data/cora-proposed-memory-updates.archive.jsonl
data/*.jsonl.bak-*
