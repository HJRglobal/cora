# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Project Settings → API → Project URL and anon/service keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Twilio (SMS OTP + notifications) ────────────────────────────────────────
# Create a free account at https://twilio.com
# Console → Account Info → Account SID and Auth Token
# Buy one phone number (~$1/month) for the sender
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+18005551234

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://coverage.lexingtonservices.com
# Local dev: http://localhost:3000
