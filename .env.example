# -----------------------------------------------------------------------------
# Drive (G:) mount resilience — drive_io wrapper (2026-07-16)
# -----------------------------------------------------------------------------
# All defaults are production-correct; override only for tuning/tests. The wrapper
# makes every local G: read/write timeout-bounded + retried so a transient Google-
# Drive unmount/remount can never freeze the bot (it degrades to cached context).
# DRIVE_IO_MOUNT_ANCHOR=G:\My Drive\HJR-Founder-OS   # optional; reachability-probe anchor; default this path
# DRIVE_IO_TIMEOUT_SECONDS=10                        # optional; per-attempt worker join deadline; default 10
# DRIVE_IO_RETRY_SECONDS=90                          # optional; default (scheduled-job) retry window; default 90
# DRIVE_IO_BACKOFF_SECONDS=1                         # optional; sleep between retry attempts; default 1
# DRIVE_IO_BREAKER_SECONDS=30                        # optional; circuit-breaker fast-fail window after a confirmed outage; default 30
# DRIVE_IO_MONITOR_INTERVAL_SECS=300                 # optional; G: reachability breadcrumb probe interval (Slice 4, observability only); default 300

# -----------------------------------------------------------------------------
# Clover POS — RETIRED portfolio-wide 2026-06-06 (D-027 / D-032)
# -----------------------------------------------------------------------------
# All OSN/retail financial data is QBO-only; the CLOVER_* keys are intentionally
# removed. Do not reintroduce.

# -----------------------------------------------------------------------------
# Legacy / retired paths — kept for reference; NOT read by current src/ code
# -----------------------------------------------------------------------------
# Apollo.io — the F3 LinkedIn Spy scanner migrated to Make.com (scenario 4769263,
# sole owner) and the Python path + host task were retired 2026-06-16. APOLLO_API_KEY
# is no longer read by any src/ module; kept here only for reference/reactivation.
# (LINKEDIN_SPY_CHANNEL removed 2026-07-03 — dead key, W9-04.)
# APOLLO_API_KEY=your-apollo-api-key-here            # LEGACY — not read by current code
