PERPLEXITY_API_KEY=your-perplexity-key-here          # optional; default "" (Perplexity surface off)
GEMINI_API_KEY=your-gemini-api-key-here              # optional; default "" (Gemini-grounded surface off). Distinct from the Google service account.
OTTERLY_API_KEY=your-otterly-api-key-here            # optional; default "" (Google AI Overviews slice off). Single-workspace scoped.
# AI_VISIBILITY_CHANNEL=f3-ai-visibility             # optional; default C0BFXEJ1UJU (#f3-ai-visibility). --channel overrides.
# --- tuning (all optional; sensible defaults) ---
# AI_VIS_PERPLEXITY_MODEL=sonar                      # optional; default sonar
# AI_VIS_OPENAI_MODEL=gpt-4.1                        # optional; default gpt-4.1 (Responses API web_search)
