# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Slack app credentials — from https://api.slack.com/apps
# Phase 1 transport: Socket Mode. SLACK_APP_TOKEN (xapp-) carries Socket Mode events.
# SLACK_BOT_TOKEN (xoxb-) is still required for posting messages.
# SLACK_SIGNING_SECRET is unused under Socket Mode but kept for future HTTPS migration.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Anthropic API key — from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Asana Personal Access Token — from https://app.asana.com/0/my-apps
# Optional: Cora boots without it, but Asana tool-use (e.g. "what should I work on")
# will respond with a graceful error if asked. Single-PAT model: this is Harrison's
# token and Cora queries Asana as Harrison. Phase 3 may migrate to per-user OAuth.
ASANA_PAT=2/your-asana-pat-here

# HubSpot Private App Token — from HubSpot Settings → Integrations → Private Apps
# Optional. Read-only scopes only (deals/contacts/companies/pipelines read).
# HJR Global portal ID: 243870963 (used for deep-link URL construction in hubspot_client).
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token-here

# Google Service Account JSON path — for Calendar tool via Domain-wide Delegation.
# Optional. Path to the service account JSON key file (gitignored under .credentials/).
# Service account: cora-calendar@cora-calendar-readonly.iam.gserviceaccount.com
# Authorized scope: https://www.googleapis.com/auth/calendar.readonly
# Setup steps in deployment/runbook.md.
GOOGLE_SERVICE_ACCOUNT_JSON=C:\Users\Harri\code\cora\.credentials\cora-calendar-sa.json

# OpenAI API key — for Phase 3 Knowledge Base embeddings (text-embedding-3-small).
# Optional. If missing, KB ingest + retrieval no-op gracefully (bot still works without RAG).
# Set monthly budget cap at https://platform.openai.com/usage/limits — recommended $50.
OPENAI_API_KEY=your-openai-key-here

# Fireflies API key — for Phase 3B Fireflies connector (transcript ingestion into KB).
# Optional. If missing, Fireflies backfill/sync errors gracefully and bot stays functional.
# Generate at: https://app.fireflies.ai/settings → Developer Settings → API Access.
# Connector also accepts FIREFLIES_API_TOKEN or FIREFLIES_TOKEN as fallback var names.
FIREFLIES_API_KEY=your-fireflies-token-here

# QuickBooks Online OAuth credentials — Phase 2 #10. App-level credentials from the
# Intuit Developer Portal (https://developer.intuit.com → My Apps → your app).
# All four optional. If any are missing, QBO tool-use is disabled and the bot still works.
# Per-entity OAuth tokens (one set per QBO company) are persisted to
# .credentials/qbo-tokens.json — see scripts/qbo_oauth_flow.py.
QBO_CLIENT_ID=your-intuit-app-client-id
QBO_CLIENT_SECRET=your-intuit-app-client-secret
# Redirect URI must EXACTLY match the value registered in the Intuit Developer
# Portal (Settings -> Redirect URIs) for the matching app environment.
#
# Intuit gotcha: the portal rejects https://localhost:* with "Please enter a
# unique valid redirect URI" because localhost normalizes to 127.0.0.1 (an IP)
# and Intuit's validator forbids IP-address redirect URIs. http://localhost:*
# is whitelisted as a developer convenience and is accepted on both tabs.
#
# Working configurations:
#   Sandbox (Development tab):
#     http://localhost:8765/qbo-oauth-callback
#   Production (Production tab) - two paths:
#     A) http://localhost:8766/qbo-oauth-callback           if Intuit's runtime
#        accepts HTTP+localhost for production (form accepts it; verify at
#        first OAuth flow once Compliance forms unlock the app).
#     B) https://cora-oauth.<your-domain>/qbo-oauth-callback if Path A fails -
#        stand up a Cloudflare Tunnel from that public hostname to
#        http://localhost:8766 and register the tunnel URL on the Production
#        tab. Tunnel terminates TLS at the edge; local server stays HTTP.
#
# The qbo_oauth.py callback server reads the scheme from this value: http ->
# plain TCP; https -> self-signed TLS via .credentials/oauth-cert.{crt,key}.
# The HTTPS branch is currently unreachable via Intuit's portal but stays in
# the code in case we ever terminate TLS locally instead of at a tunnel edge.
QBO_REDIRECT_URI=http://localhost:8765/qbo-oauth-callback
QBO_ENVIRONMENT=production

# Instagram Graph API — F3 brand accounts (influencer scanner)
# See deployment/META_SETUP_GUIDE.md for the full token generation walkthrough.
# Short-lived tokens expire in ~1 hour; always exchange for Long-Lived Tokens (60-day).
# Cora auto-refreshes tokens when ≤10 days remain — scanner must run at least once
# in that window. If a token fully expires, repeat Steps 3–4 of the setup guide.
#
# How to get these values:
#   User IDs  — Step 5 of META_SETUP_GUIDE.md (numeric, looks like 17841400000000001)
#   Tokens    — Step 4 of META_SETUP_GUIDE.md (long string starting with IGQV or EAAG)
#
# F3 Energy (@f3energy)
INSTAGRAM_F3E_USER_ID=<numeric IG Business Account ID>
INSTAGRAM_F3E_ACCESS_TOKEN=<long-lived user access token>
#
# F3 Mood (@drinkf3mood)
INSTAGRAM_F3MOOD_USER_ID=<numeric IG Business Account ID>
INSTAGRAM_F3MOOD_ACCESS_TOKEN=<long-lived user access token>
#
# F3 Pure (@f3pure)
INSTAGRAM_F3PURE_USER_ID=<numeric IG Business Account ID>
INSTAGRAM_F3PURE_ACCESS_TOKEN=<long-lived user access token>
#
# Slack channel to post influencer detection alerts (without the #).
# Defaults to f3-sales if not set.
INFLUENCER_SCAN_NOTIFY_CHANNEL=f3-sales

# Optional overrides
# LOG_LEVEL=INFO
# GSHEETS_CASHFLOW_SHEET_NAME=CF_SUMMARY  # override if tab is renamed
# Socket Mode doesn't bind a port; PORT only matters if/when we move to HTTPS.

# Polar Analytics API key — for Cora ad performance tools (Tools 1-5 in ads territory).
# Generate at: app.polaranalytics.com → Settings → API → Create API Key
# Optional. If missing, ads tools gracefully return UNKNOWN_RESPONSE + notify #f3e-marketing.
# Pre-build gate: reconnect Polar connector in Cowork (v1 → v3.7) before first test run.
POLAR_API_KEY=your-polar-api-key-here

# Polar Analytics view ID — scopes ad queries to the F3 Energy brand view.
# Default: 31499-mot5h6ya (confirmed 2026-05-23). Only override if the view changes.
POLAR_VIEW_ID=31499-mot5h6ya

# Make.com webhook URL — F3 sales deck generation pipeline.
# How to get: Make.com → Create Scenario → Webhook trigger → Copy webhook URL
# The scenario should: receive payload → Canva fill template → export PDF → Drive upload → Slack DM
# Optional. If missing, the f3_create_sales_deck tool returns a friendly config error.
# See design/make-sales-deck-webhook-spec.md for the full payload schema.
MAKE_SALES_DECK_WEBHOOK_URL=https://hook.us1.make.com/your-webhook-id-here

# Polar Analytics view ID — scopes ad queries to the F3 Energy brand view.
# Default: 31499-mot5h6ya (confirmed 2026-05-23). Only override if the view ID changes.
POLAR_VIEW_ID=31499-mot5h6ya
