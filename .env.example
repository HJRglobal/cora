# =============================================================================
# Cora — environment configuration template
# =============================================================================
# Copy this file to .env and fill in real values. .env is gitignored — never
# commit real secrets.
#
# CONVENTION (regenerated 2026-07-03, audit W9-01):
#   * Every env var read anywhere under src/ is documented here, grouped by
#     domain, with its CODE DEFAULT and a one-line purpose.
#   * Secrets/tokens show a placeholder value. Feature flags and paths show
#     their real code default (or are shown commented when the default is a
#     repo/Drive path you normally should NOT override).
#   * RESERVED operational flags (e.g. the drive-extractor pause) carry their
#     ratified value here so a rebuild-from-this-file reproduces the intended
#     runtime state — NOT the raw code default.
#   * A guardrail test (tests/test_env_example_coverage.py) fails if any
#     os.environ/getenv key read in src/ is missing from this file. Keep them
#     in sync: when you add an env read, document it here.
# =============================================================================


# -----------------------------------------------------------------------------
# Slack — https://api.slack.com/apps
# -----------------------------------------------------------------------------
# Phase 1 transport is Socket Mode. SLACK_APP_TOKEN (xapp-) carries Socket Mode
# events; SLACK_BOT_TOKEN (xoxb-) posts messages. SLACK_SIGNING_SECRET is unused
# under Socket Mode but validated at boot (required) for a future HTTPS move.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here            # required
SLACK_APP_TOKEN=xapp-your-app-level-token-here      # required (Socket Mode)
SLACK_SIGNING_SECRET=your-signing-secret-here       # required (config._load validates)
# SLACK_USER_TOKEN (xoxp-) — user-scoped token for Business+ read/search the bot
# token can't do. Read by scripts (e.g. archive_sprawl_channels.py), not the bot.
SLACK_USER_TOKEN=xoxp-your-user-token-here          # optional (scripts only)

# -----------------------------------------------------------------------------
# Anthropic — https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here              # required
# Pre-send input-token ceiling (D-084). The token-budget guard in claude_client
# trims an over-ceiling request (KB chunks, then the wholesale founder Current
# State of the World) rather than let it 400 at Anthropic's 200,000 input max.
# Default 185000 leaves headroom for estimator variance; raise/lower only to tune.
# CLAUDE_MAX_INPUT_TOKENS=185000                      # optional; default 185000

# -----------------------------------------------------------------------------
# OpenAI — Phase 3 KB embeddings (text-embedding-3-small)
# -----------------------------------------------------------------------------
# Optional; if missing, KB ingest + retrieval no-op gracefully (bot still works).
OPENAI_API_KEY=your-openai-key-here                 # optional; default "" (KB off)

# -----------------------------------------------------------------------------
# Asana — https://app.asana.com/0/my-apps
# -----------------------------------------------------------------------------
# Optional: Cora boots without it; Asana tool-use responds with a graceful error.
# Single-PAT model — Harrison's token; Cora queries Asana as Harrison.
ASANA_PAT=2/your-asana-pat-here                     # optional; default "" (Asana off)

# -----------------------------------------------------------------------------
# HubSpot — Settings → Integrations → Private Apps (portal 246351746)
# -----------------------------------------------------------------------------
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token-here  # optional; default "" (HubSpot off)
# Canonical portal. The D-030 runtime guard in hubspot_client.py asserts the live
# token resolves to this portal before any read/write; a mismatch is refused.
HUBSPOT_PORTAL_ID=246351746                         # default 246351746
# Escape hatch for the D-030 portal guard. Leave UNSET in production. Setting =1
# disables the portal assertion (only for a deliberate migration/test).
# CORA_DISABLE_HUBSPOT_PORTAL_GUARD=1               # default unset (guard ON)

# -----------------------------------------------------------------------------
# Google service account (Calendar + Drive sweep + filer via DWD)
# -----------------------------------------------------------------------------
# Path to the service-account JSON key (gitignored under .credentials/).
# SA: cora-calendar@cora-calendar-readonly.iam.gserviceaccount.com. Setup: runbook.md.
GOOGLE_SERVICE_ACCOUNT_JSON=C:\Users\Harri\code\cora\.credentials\cora-calendar-sa.json  # optional; default ""
# Drive root folder id for the HJR-Founder-OS tree (Drive sweep + filer).
CORA_DRIVE_ROOT_FOLDER_ID=your-drive-root-folder-id # optional; default "" (drive tools degrade)
# DWD user to impersonate for Drive/Sheets reads. Defaults to the code default
# impersonation account; override only to read as a different domain user.
# CORA_DRIVE_IMPERSONATE=harrison@hjrglobal.com     # optional; default = _DEFAULT_IMPERSONATE
# Root of the Claude Code transcript store for the session-capture harvester.
# CLAUDE_PROJECTS_ROOT=C:\Users\Harri\.claude\projects  # optional; default = ~/.claude/projects
# Founder-OS root (session capture + cashflow snapshot writers).
# FOUNDER_OS_ROOT=G:\My Drive\HJR-Founder-OS         # optional; default = G:\My Drive\HJR-Founder-OS
# Cowork desktop agent-mode transcript root (session capture second source).
# Leave unset; the harvester auto-discovers it under %LOCALAPPDATA%\Packages\*laude*.
# COWORK_SESSIONS_ROOT=                               # optional; default = auto-discover
# LOCALAPPDATA=                                       # OS-provided (Windows); read only to auto-discover the Cowork store above -- never set this here

# -----------------------------------------------------------------------------
# Notion — KB sync of Notion databases
# -----------------------------------------------------------------------------
NOTION_API_KEY=your-notion-internal-integration-token-here  # optional; default "" (Notion sync off)
# Comma-separated extra Notion database ids to sync (beyond the primary set).
# NOTION_EXTRA_DB_IDS=id1,id2,id3                    # optional; default "" (none)

# -----------------------------------------------------------------------------
# Airtable — read-only dashboard CRM readers (creator CRM + content pipeline)
# -----------------------------------------------------------------------------
# Read-only Personal Access Token scoped to the two dashboard bases
# (appwF6W6eVTvPFjct + appxbEBjIBf8Wwlbd). The connector refuses any other base.
AIRTABLE_API_KEY=your-airtable-readonly-pat-here    # optional; default "" (dashboard CRM readers off)

# -----------------------------------------------------------------------------
# Fireflies — transcript ingestion into KB (Phase 3B)
# -----------------------------------------------------------------------------
# Optional. Connector tries FIREFLIES_API_KEY, then FIREFLIES_API_TOKEN, then
# FIREFLIES_TOKEN (first non-empty wins). Generate at app.fireflies.ai/settings.
FIREFLIES_API_KEY=your-fireflies-token-here         # optional; default "" (Fireflies off)
# FIREFLIES_API_TOKEN=                              # optional fallback var name
# FIREFLIES_TOKEN=                                  # optional fallback var name

# -----------------------------------------------------------------------------
# QuickBooks Online OAuth — Intuit Developer Portal
# -----------------------------------------------------------------------------
# All four optional; if any missing, QBO tool-use is disabled and the bot works.
# Per-entity tokens persist to .credentials/qbo-tokens.json (scripts/qbo_oauth_flow.py).
QBO_CLIENT_ID=your-intuit-app-client-id             # optional; default ""
QBO_CLIENT_SECRET=your-intuit-app-client-secret     # optional; default ""
# Redirect URI must EXACTLY match the Intuit portal registration for the env.
# Intuit rejects https://localhost:* (localhost→127.0.0.1, an IP); http://localhost:*
# is accepted. Callback scheme: http→plain TCP, https→self-signed TLS.
QBO_REDIRECT_URI=http://localhost:8765/qbo-oauth-callback  # default http://localhost:8765/qbo-oauth-callback
QBO_ENVIRONMENT=production                          # default production

# -----------------------------------------------------------------------------
# Shopify Admin API — F3 Energy DTC store
# -----------------------------------------------------------------------------
# OAuth offline access token (legacy custom apps deprecated 2026-01-01).
SHOPIFY_F3E_STORE=f3energy.myshopify.com            # optional; default "" (Shopify off)
SHOPIFY_F3E_ACCESS_TOKEN=your-shopify-offline-access-token  # optional; default ""
SHOPIFY_F3E_API_KEY=your-shopify-app-api-key        # optional; default ""
SHOPIFY_F3E_API_SECRET=your-shopify-app-api-secret  # optional; default ""

# -----------------------------------------------------------------------------
# Polar Analytics — ad-performance tools (F3E ads territory)
# -----------------------------------------------------------------------------
# Optional; if missing, ads tools return UNKNOWN_RESPONSE + notify #f3e-marketing.
POLAR_API_KEY=your-polar-api-key-here               # optional; default ""
# View id scoping ad queries to the F3 Energy brand view.
POLAR_VIEW_ID=31499-mot5h6ya                         # default 31499-mot5h6ya
# OAuth client-credentials (Polar MCP token exchange). Optional; blank → OAuth off.
POLAR_CLIENT_ID=your-polar-client-id                # optional; default ""
POLAR_CLIENT_SECRET=your-polar-client-secret        # optional; default ""
# Endpoint overrides — leave unset; sensible code defaults ship in polar_client.py.
# POLAR_API_BASE_URL=                               # optional; default = _API_BASE_URL_DEFAULT
# POLAR_MCP_URL=                                    # optional; default = _MCP_ENDPOINT_DEFAULT
# POLAR_OAUTH_URL=                                  # optional; default = _OAUTH_TOKEN_URL_DEFAULT

# -----------------------------------------------------------------------------
# PhotoRoom — product image background removal (creative tool)
# -----------------------------------------------------------------------------
# Optional; PhotoRoom tool-use disabled if PHOTOROOM_API_KEY is missing.
PHOTOROOM_API_KEY=your-photoroom-api-key            # optional; default ""
PHOTOROOM_BASE_URL=https://image-api.photoroom.com/v2  # default https://image-api.photoroom.com/v2
PHOTOROOM_OUTPUTS_DRIVE_FOLDER_ID=your-photoroom-outputs-drive-folder-id  # optional; default ""
# PHOTOROOM_RATE_LIMIT_PER_MIN=60                   # default 60
# PHOTOROOM_USE_SANDBOX=false                       # default false
# PHOTOROOM_WEEKLY_BUDGET_USD=50                    # default 50

# -----------------------------------------------------------------------------
# Make.com — F3 sales deck generation pipeline webhook
# -----------------------------------------------------------------------------
# Optional; f3_create_sales_deck returns a config error if missing.
MAKE_SALES_DECK_WEBHOOK_URL=https://hook.us1.make.com/your-webhook-id-here  # optional; default ""

# -----------------------------------------------------------------------------
# Curated financial Google Sheet (Standing ACTUALS cashflow reader)
# -----------------------------------------------------------------------------
GSHEETS_CASHFLOW_FILE_ID=your-cashflow-sheet-file-id  # optional; default "" (cashflow tool degrades)
# Tab name to read from the cashflow sheet. Override only if the tab is renamed.
# GSHEETS_CASHFLOW_SHEET_NAME=CF_SUMMARY            # default CF_SUMMARY

# -----------------------------------------------------------------------------
# F3E warehouse inventory Google Sheet (Cotton 3PL SKU pulse)
# -----------------------------------------------------------------------------
# F3E_INVENTORY_FILE_ID=your-f3e-inventory-sheet-file-id  # optional; default "" (inventory tool degrades)

# -----------------------------------------------------------------------------
# Fighter / influencer compliance tracker Google Sheet (MMA Lab x F3)
# -----------------------------------------------------------------------------
FIGHTER_TRACKER_SHEET_ID=your-fighter-tracker-sheet-id  # optional; default "" (tracker tool degrades)

# -----------------------------------------------------------------------------
# Instagram / Meta — influencer scanner (see deployment/META_SETUP_GUIDE.md)
# -----------------------------------------------------------------------------
# Short-lived tokens expire ~1h; always exchange for Long-Lived (60-day) tokens.
# NOTE (2026-07-03 audit): META_APP_ID/SECRET + the INSTAGRAM_* vars are read by
# the Meta app setup / token-generation path and the influencer scanner scripts,
# not by the always-on bot's src/ modules. Keep them set if the scanner runs.
INSTAGRAM_F3E_USER_ID=<numeric IG Business Account ID>
INSTAGRAM_F3E_ACCESS_TOKEN=<long-lived user access token>
INSTAGRAM_F3MOOD_USER_ID=<numeric IG Business Account ID>
INSTAGRAM_F3MOOD_ACCESS_TOKEN=<long-lived user access token>
INSTAGRAM_F3PURE_USER_ID=<numeric IG Business Account ID>
INSTAGRAM_F3PURE_ACCESS_TOKEN=<long-lived user access token>
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Slack channel (no #) for influencer detection alerts. Read by run_influencer_scan.py.
INFLUENCER_SCAN_NOTIFY_CHANNEL=f3-sales             # default f3-sales

# -----------------------------------------------------------------------------
# Email attachment auto-filer — scripts/run_attachment_filer.py
# -----------------------------------------------------------------------------
# Reuses GOOGLE_SERVICE_ACCOUNT_JSON + ANTHROPIC_API_KEY + SLACK_BOT_TOKEN.
# DWD scope needed per monitored account: .../auth/gmail.modify
EMAIL_FILING_NOTIFY_CHANNEL=cora-filing             # default cora-filing (bot must be a member)
EMAIL_FILING_LOOKBACK_HOURS=24                      # default 24 (first-run backfill window)
# Per-run self-budget (seconds) before the filer stops and resumes next run.
# EMAIL_FILING_RUN_BUDGET_SECONDS=780               # default 780 (13 min < 20-min task limit)
# Crash-safe dedup ledgers (D-053). Leave unset; default to data/state/*.jsonl.
# FILER_CONTENT_LEDGER_PATH=                        # optional; default = data/state/filer-content-ledger.jsonl
# FILER_MESSAGE_LEDGER_PATH=                        # optional; default = data/state/filer-message-ledger.jsonl
# FILER_CONTENT_TTL_DAYS=365                         # default 365
# FILER_MESSAGE_TTL_DAYS=60                           # default 60

# -----------------------------------------------------------------------------
# Finance receipt digest — scripts/run_finance_receipt_digest.py (W4-02)
# -----------------------------------------------------------------------------
# The weekly digest posts to the pinned #hjr-finance channel (channel_id in
# data/maps/finance-receipt-allowlist.yaml). If that post fails (e.g. the
# channel is archived), a metadata-only DELIVERY-FAILURE alert (no vendor/amount
# lines — the finance firewall) goes to a live ops channel instead. Resolution
# order: FINANCE_DIGEST_FALLBACK_CHANNEL -> HEALTH_REPORT_CHANNEL -> hjrg-leadership.
# FINANCE_DIGEST_FALLBACK_CHANNEL=                   # optional; else HEALTH_REPORT_CHANNEL, else hjrg-leadership
# HEALTH_REPORT_CHANNEL=hjrg-leadership              # also read by scripts/nightly_health_check.py; default hjrg-leadership

# -----------------------------------------------------------------------------
# OSN shift scheduler
# -----------------------------------------------------------------------------
# Comma-separated Slack user IDs allowed to run generate/approve/publish.
OSN_SCHEDULER_ADMIN_USER_IDS=U0B2RM2JYJ1,U0B3PS7RFJA,U0B4L78SZHN  # OPERATIONAL value (Harrison,Matt,Micah); code default is "" (no admin if unset)
# Slack channel (no #) where schedule drafts post for ✅ approval.
OSN_SCHEDULER_APPROVAL_CHANNEL=osn-scheduling       # default osn-scheduling

# -----------------------------------------------------------------------------
# Uptime monitoring (Stage 2 — 2026-06-11)
# -----------------------------------------------------------------------------
# Local /health endpoint. 200+JSON while heartbeat is fresh (<180s), else 503.
# HEALTH_PORT=0 disables. Binds 127.0.0.1 by default; widen HEALTH_BIND only for
# a tunnel/LAN probe.
HEALTH_PORT=8787                                    # default 8787
HEALTH_BIND=127.0.0.1                               # default 127.0.0.1
# Outbound dead-man ping (healthchecks.io / UptimeRobot heartbeat). Blank disables.
HEALTH_PING_URL=                                    # default "" (disabled)
HEALTH_PING_INTERVAL_S=300                          # default 300

# -----------------------------------------------------------------------------
# Security monitor — scripts/security_monitor.py
# -----------------------------------------------------------------------------
SECURITY_ALERT_CHANNEL=cora-build                   # default cora-build

# -----------------------------------------------------------------------------
# Logging + identity
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO                                    # default INFO
# Harrison's Slack user id — used by knowledge_review as the sole approver (D-011).
# HARRISON_SLACK_USER_ID=U0B2RM2JYJ1                # default U0B2RM2JYJ1

# -----------------------------------------------------------------------------
# Knowledge base + known-answers + path overrides
# -----------------------------------------------------------------------------
# The live bot points KNOWN_ANSWERS_DIR at the Drive _brain store; unset falls
# back to the in-repo design/known-answers/. All *_DIR/*_PATH below default to
# sensible repo/Drive paths — leave unset unless relocating data.
# CORA_KB_DB_PATH=                                  # optional; default = data/cora_kb.db
# KNOWN_ANSWERS_DIR=                                # optional; default = design/known-answers  (live: _brain/known-answers)
# DYNAMIC_ANSWERS_DIR=                              # optional; default = design/known-answers/dynamic
# BRAIN_PEOPLE_DIR=                                 # optional; default = _brain/people (person dossiers)
# SWEPT_DIR=                                        # optional; default = _brain/swept (materializer export)
# FLYWHEEL_MIRROR_DIR=                              # optional; default = _brain/_flywheel (ledger mirror)
# MATERIALIZER_KB_DB_PATH=                          # optional; default = data/cora_kb.db (materializer read)
# MATERIALIZATION_WATERMARK_PATH=                   # optional; default = data/state/materialization-watermark.json

# -----------------------------------------------------------------------------
# Feature flags — proactive-emitter gates (Phase 0 rebuild, 2026-06-16)
# -----------------------------------------------------------------------------
# These emitters are MUTED by default (empty ⇒ off). Set true only once a
# surface's precision/data is trusted. Reads live in the scheduled-task scripts.
# CASH_PULSE_ENABLED=true                           # default off  (daily Cash Pulse push; run_cashflow_pulse.py)
# CORA_HUBSPOT_EMAIL_SYNC_DM_ENABLED=true           # default off  (HubSpot email-match DM prompts)
# COMPLETION_SWEEP_POST_ENABLED=true                # default off  (completion-candidate digest)
# DECISION_CAPTURE_POST_ENABLED=true                # default off  (decision-capture digest)
# CORA_EVAL_MODE=1                                  # default off  (KB eval harness; test/eval runs only)

# -----------------------------------------------------------------------------
# RESERVED operational flags — set to the RATIFIED value, NOT the code default
# -----------------------------------------------------------------------------
# ⚠️ drive-extractor proposals are PAUSED (D-066, ratified 2026-07-02). The CODE
#    DEFAULT is "1" (ENABLED) — so this MUST be present as =0 or a rebuild from
#    this template would silently RE-ENABLE the pause. Do not flip without a
#    ratified decision (RESERVED). This is the W9-01 silent-reversal fix.
DRIVE_EXTRACTOR_PROPOSALS_ENABLED=0                 # code default "1"; RATIFIED = 0 (PAUSED, D-066)
# DRIVE_EXTRACTOR_MAX_PROPOSALS_PER_RUN=50          # default 50 (cap when un-paused)
# Graduated-trust SHADOW instrumentation. Default ON = measurement only; it
# flips NOTHING (D-063). The actual graduated-trust FLIP is a separate reserved
# decision — do not conflate turning shadow off with flipping trust on.
# CORA_GRADUATED_SHADOW=0                            # default ON (measurement-only)
# CORA_GRADUATED_SHADOW_DIR=                         # optional; default = logs/
# Graduated-trust AUTO-WRITE FLIP (2026-07-21, D-011 relaxed -> reversible). The
# shadow above measures; THIS flips it live. Default OFF = today's behavior (every
# knowledge item DMs Harrison). 'tier0' = only CORROBORATED+allowlist+recognized
# items auto-write; 'all' = Tier-0 AND Tier-1. Tier-2 (money/contracts/legal/
# equity/comp/PHI/LEX/cross-entity/conflicts-with-canon) is NEVER auto-written.
# Every auto-write is audited (logs/cora-autowrite-audit.jsonl) + one-tap
# revertible in the weekly cowork-cora-autowrite-digest. Restart to take effect.
# CORA_AUTOWRITE_LIVE=off                            # off (default) | tier0 | all
# CORA_GAP_DETECT_DAILY_CAP=                         # optional; default = _DEFAULT_DAILY_CAP (gap-detection DM cap)
# CORA_KB_MISS_SHADOW_FLOOR=                          # optional; default 1.10 (PROVISIONAL, LOG-ONLY kb_miss shadow floor; never gates)
# KB_DECISION_LOG_PATH=                              # optional; default = logs/kb-retrieval-decisions.jsonl (per-query retrieval-decision + shadow stream)

# -----------------------------------------------------------------------------
