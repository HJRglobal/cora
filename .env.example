# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Slack app credentials — from https://api.slack.com/apps
# Phase 1 transport: Socket Mode. SLACK_APP_TOKEN (xapp-) carries Socket Mode events.
# SLACK_BOT_TOKEN (xoxb-) is still required for posting messages.
# SLACK_SIGNING_SECRET is unused under Socket Mode but kept for future HTTPS migration.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Anthropic API key — from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Asana Personal Access Token — from https://app.asana.com/0/my-apps
# Optional: Cora boots without it, but Asana tool-use (e.g. "what should I work on")
# will respond with a graceful error if asked. Single-PAT model: this is Harrison's
# token and Cora queries Asana as Harrison. Phase 3 may migrate to per-user OAuth.
ASANA_PAT=2/your-asana-pat-here

# HubSpot Private App Token — from HubSpot Settings → Integrations → Private Apps
# Optional. Read-only scopes only (deals/contacts/companies/pipelines read).
# HJR Global portal ID: 243870963 (used for deep-link URL construction in hubspot_client).
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token-here

# Google Service Account JSON path — for Calendar tool via Domain-wide Delegation.
# Optional. Path to the service account JSON key file (gitignored under .credentials/).
# Service account: cora-calendar@cora-calendar-readonly.iam.gserviceaccount.com
# Authorized scope: https://www.googleapis.com/auth/calendar.readonly
# Setup steps in deployment/runbook.md.
GOOGLE_SERVICE_ACCOUNT_JSON=C:\Users\Harri\code\cora\.credentials\cora-calendar-sa.json

# OpenAI API key — for Phase 3 Knowledge Base embeddings (text-embedding-3-small).
# Optional. If missing, KB ingest + retrieval no-op gracefully (bot still works without RAG).
# Set monthly budget cap at https://platform.openai.com/usage/limits — recommended $50.
OPENAI_API_KEY=your-openai-key-here

# Fireflies API key — for Phase 3B Fireflies connector (transcript ingestion into KB).
# Optional. If missing, Fireflies backfill/sync errors gracefully and bot stays functional.
# Generate at: https://app.fireflies.ai/settings → Developer Settings → API Access.
# Connector also accepts FIREFLIES_API_TOKEN or FIREFLIES_TOKEN as fallback var names.
FIREFLIES_API_KEY=your-fireflies-token-here

# Optional overrides
# LOG_LEVEL=INFO
# Socket Mode doesn't bind a port; PORT only matters if/when we move to HTTPS.
