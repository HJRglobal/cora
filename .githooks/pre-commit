#!/bin/sh
# Architecture decision #10 rider — non-negotiable from commit 1.
# Blocks commits containing real Anthropic / Slack / Asana / HubSpot / Google key material.
#
# Patterns match actual key formats, not human-readable placeholder text:
#   sk-ant-api          — all live Anthropic keys start with sk-ant-api (e.g. sk-ant-api03-)
#   xoxb-[0-9]          — real Slack bot tokens have digit-only segments (e.g. xoxb-12345678-)
#   xoxp-[0-9]          — real Slack user tokens (same format)
#   xapp-1-A[0-9]       — Slack app-level tokens for Socket Mode
#   2/[0-9]{10,}/       — Asana PATs (format: 2/{user_gid}/{token}, gid is 10+ digits)
#   pat-na[0-9]-        — HubSpot Private App tokens (e.g. pat-na1-..., pat-na2-...)
#   BEGIN PRIVATE KEY   — defends against accidentally-committed Google Service Account JSON
#                          (the private_key field always contains this header)
#   sk-proj-[A-Za-z0-9]   — OpenAI project-scoped API keys (Phase 3 embeddings)
#   sk-[A-Za-z0-9]{20,}   — OpenAI legacy user keys (broader pattern as backstop)
#   FIREFLIES_API_KEY=    — Fireflies API keys are UUIDs (no unique prefix), so we
#                            match the env-var-assignment pattern with a UUID-shaped value.
#   IGQV / EAAG           — Instagram Graph API long-lived user tokens (Phase 3)

STAGED=$(git diff --cached --name-only | grep -v "^\.githooks/")

if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=$(printf '%s\n' $STAGED | xargs grep -lE "sk-ant-api|xoxb-[0-9]|xoxp-[0-9]|xapp-1-A[0-9]|2/[0-9]{10,}/|pat-na[0-9]-|BEGIN PRIVATE KEY|sk-proj-[A-Za-z0-9]|FIREFLIES_API_KEY=[0-9a-f]{8}-[0-9a-f]{4}|IGQV[A-Za-z0-9]|EAAG[A-Za-z0-9]" 2>/dev/null)

if [ -n "$FOUND" ]; then
  echo ""
  echo "  BLOCKED: potential API key detected in staged files."
  echo "  Matched files:"
  for f in $FOUND; do
    echo "    $f"
  done
  echo ""
  echo "  Remove secrets and store them in .env (which is gitignored)."
  echo ""
  exit 1
fi
