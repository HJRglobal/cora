#!/bin/sh
# Architecture decision #10 rider — non-negotiable from commit 1.
# Blocks commits containing real Anthropic or Slack API key material.
#
# Patterns match actual key formats, not human-readable placeholder text:
#   sk-ant-api   — all live Anthropic keys start with sk-ant-api (e.g. sk-ant-api03-)
#   xoxb-[0-9]   — real Slack bot tokens have digit-only segments (e.g. xoxb-12345678-)
#   xoxp-[0-9]   — real Slack user tokens (same format)

STAGED=$(git diff --cached --name-only | grep -v "^\.githooks/")

if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=$(printf '%s\n' $STAGED | xargs grep -lE "sk-ant-api|xoxb-[0-9]|xoxp-[0-9]" 2>/dev/null)

if [ -n "$FOUND" ]; then
  echo ""
  echo "  BLOCKED: potential API key detected in staged files."
  echo "  Matched files:"
  for f in $FOUND; do
    echo "    $f"
  done
  echo ""
  echo "  Remove secrets and store them in .env (which is gitignored)."
  echo ""
  exit 1
fi
